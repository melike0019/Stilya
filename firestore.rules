rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Kullanıcı profil belgesi ────────────────────────────────────────────
    // Sadece hesap sahibi okuyabilir / yazabilir
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // ── Kıyafet alt koleksiyonu ─────────────────────────────────────────
      match /clothing/{itemId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      // ── Kombin alt koleksiyonu ──────────────────────────────────────────
      match /outfits/{outfitId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }

      // ── Ajanda alt koleksiyonu ──────────────────────────────────────────
      match /planner/{planId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }
  }
}
